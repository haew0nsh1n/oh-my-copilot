.DS_Store
Thumbs.db

# Editor and IDE state
.vscode/
!.vscode/
!.vscode/tasks.json
.idea/
*.swp
*.swo

# Logs and temporary files
*.log
tmp/
temp/

# In-repo git worktrees created for parallel development
.worktrees/

# Local OMP runtime state (project-scoped skills remain shareable)
.omp/*
!.omp/skills/
!.omp/skills/**
!.omp/plans/
!.omp/plans/**

# Environment and secrets
.env
.env.*
!.env.example

# JavaScript / TypeScript
node_modules/
dist/
build/
coverage/
.next/
*.tsbuildinfo
apps/**/.next/
apps/**/*.tsbuildinfo

# Python
.coverage
__pycache__/
*.py[cod]
.pytest_cache/
apps/**/.pytest_cache/
*.egg-info/
apps/**/*.egg-info/
.mypy_cache/
.ruff_cache/
.venv/
venv/