# Azure OpenAI settings for oh-my-copilot.
# Copy this file to .env and fill in local secret values.

# Make the editable-install CLI available after `source .env`.
export PATH="$PWD/.venv/bin:$PATH"

export AZURE_OPENAI_ENDPOINT="https://<your-aoai-resource>.openai.azure.com"
export AZURE_OPENAI_API_KEY="<your-aoai-api-key>"
export AZURE_OPENAI_CODEX_DEPLOYMENT="<your-codex-deployment-name>"
export AZURE_OPENAI_API_VERSION="2025-04-01-preview"

# Optional fallback deployment name used when AZURE_OPENAI_CODEX_DEPLOYMENT is not set.
export AZURE_OPENAI_DEPLOYMENT="<your-default-deployment-name>"
